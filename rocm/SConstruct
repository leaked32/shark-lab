import os


cpp_env = Environment(
	CXX="clang++",
	CXXFLAGS=[
		"-std=c++20",
		"-O2",
	],
)

hip_env = Environment(
	CXX="hipcc",
	CXXFLAGS=[
		"-std=c++20",
		"-O2",
	],
)


cpp_env.Tool("compilation_db")
hip_env.Tool("compilation_db")


Export("cpp_env", "hip_env")


shark = SConscript(
	"shark/SConscript",
	variant_dir="build/shark",
	duplicate=False,
)

# tell clangd infer HIP mode from hipcc
hip_env.Append(
    CXXFLAGS=[
        "-x",
        "hip",
    ],
	CPPPATH=[
		"#shark/include",
	],
)


SConscript(
	"hip-test/SConscript",
	variant_dir="build/hip-test",
	duplicate=False,
)


cpp_env.CompilationDatabase(
	"compile_commands.json"
)
